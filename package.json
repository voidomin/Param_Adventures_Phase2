{
  "name": "param-adventure",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:force": "node scripts/run-seed-force.mjs",
    "db:bootstrap:prod": "npm run db:migrate:deploy && npm run db:seed:force",
    "email": "email dev -d src/components/emails -p 3001",
    "test": "vitest run --project unit-node --project unit-ui",
    "test:watch": "vitest --project unit-node --project unit-ui",
    "test:coverage": "vitest run --project unit-node --project unit-ui --coverage",
    "test:changed": "vitest run --project unit-node --project unit-ui --changed",
    "test:fast": "vitest run --project unit-node --project unit-ui --changed --passWithNoTests",
    "test:api": "vitest run --project unit-node",
    "test:ui": "vitest run --project unit-ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@tiptap/extension-character-count": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-youtube": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.576.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.2",
    "pg": "^8.19.0",
    "prisma": "^7.5.0",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.6",
    "recharts": "^3.8.0",
    "sanitize-html": "^2.17.1",
    "tailwind-merge": "^3.5.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.2.9",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "react-email": "^5.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "overrides": {
    "hono": "^4.12.7",
    "lodash": "^4.17.23",
    "@hono/node-server": "^1.19.10",
    "effect": "^3.20.0"
  }
}
