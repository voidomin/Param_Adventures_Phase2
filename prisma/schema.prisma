generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  category    String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id                     String             @id @default(uuid())
  email                  String             @unique
  password               String?
  name                   String             @default("")
  phoneNumber            String?
  avatarUrl              String?
  roleId                 String
  isVerified             Boolean            @default(false)
  status                 UserStatus         @default(ACTIVE)
  googleId               String?            @unique
  deletedAt              DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  age                    Int?
  bloodGroup             String?
  emergencyContactName   String?
  emergencyContactNumber String?
  emergencyRelationship  String?
  gender                 String?
  resetToken             String?
  resetTokenExpiry       DateTime?
  tokenVersion           Int                @default(0)
  blogs                  Blog[]
  bookings               Booking[]
  reviews                ExperienceReview[]
  uploads                Image[]
  savedExperiences       SavedExperience[]
  managedSlots           Slot[]             @relation("SlotManager")
  assignments            TripAssignment[]   @relation("TrekLeadAssignments")
  auditLogs              AuditLog[]
  role                   Role               @relation(fields: [roleId], references: [id])
}

model Category {
  id          String               @id @default(uuid())
  name        String
  slug        String               @unique
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  icon        String?
  experiences ExperienceCategory[]
}

model Experience {
  id                  String               @id @default(uuid())
  title               String
  slug                String               @unique
  itinerary           Json
  basePrice           Decimal              @db.Decimal(10, 2)
  durationDays        Int                  @default(1)
  location            String               @default("")
  difficulty          Difficulty           @default(EASY)
  capacity            Int
  status              ExperienceStatus     @default(DRAFT)
  images              String[]
  isFeatured          Boolean              @default(false)
  startDate           DateTime?
  endDate             DateTime?
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ageRange            String?
  bestTimeToVisit     String?
  cancellationPolicy  String?
  cardImage           String?
  coverImage          String?
  dropPoints          String[]             @default([])
  dropoffTime         String?
  exclusions          Json?
  faqs                Json?
  fitnessRequirement  String?
  highlights          String[]             @default([])
  inclusions          Json?
  lastAtm             String?
  maxAltitude         String?
  maxGroupSize        Int?
  meetingPoint        String?
  meetingTime         String?
  minAge              Int?
  networkConnectivity String?
  pickupPoints        String[]             @default([])
  thingsToCarry       Json?
  trekDistance        String?
  vibeTags            String[]             @default([])
  description         Json                 @default("{}")
  blogs               Blog[]
  bookings            Booking[]
  categories          ExperienceCategory[]
  reviews             ExperienceReview[]
  savedBy             SavedExperience[]
  slots               Slot[]
}

model ExperienceCategory {
  experienceId String
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@id([experienceId, categoryId])
}

model Slot {
  id                String           @id @default(uuid())
  experienceId      String
  date              DateTime
  capacity          Int
  remainingCapacity Int
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  completedAt       DateTime?
  managerId         String?
  startedAt         DateTime?
  status            TripStatus       @default(UPCOMING)
  trekEndedAt       DateTime?
  trekStartedAt     DateTime?
  vendorContacts    Json?
  bookings          Booking[]
  experience        Experience       @relation(fields: [experienceId], references: [id])
  manager           User?            @relation("SlotManager", fields: [managerId], references: [id])
  assignments       TripAssignment[]
  tripLog           TripLog?
}

model Booking {
  id                 String               @id @default(uuid())
  userId             String
  experienceId       String
  slotId             String?
  participantCount   Int                  @default(1)
  totalPrice         Decimal              @db.Decimal(10, 2)
  bookingStatus      BookingStatus        @default(REQUESTED)
  paymentStatus      PaymentStatus        @default(PENDING)
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  attended           Boolean              @default(false)
  baseFare           Decimal              @default(0) @db.Decimal(10, 2)
  canReview          Boolean              @default(false)
  taxBreakdown       Json?
  cancellationReason String?
  cancelledAt        DateTime?
  cancelledByUserId  String?
  refundNote         String?
  refundPreference   String?
  experience         Experience           @relation(fields: [experienceId], references: [id])
  slot               Slot?                @relation(fields: [slotId], references: [id])
  user               User                 @relation(fields: [userId], references: [id])
  participants       BookingParticipant[]
  payments           Payment[]
}

model Payment {
  id                String          @id @default(uuid())
  bookingId         String
  provider          PaymentProvider @default(RAZORPAY)
  providerOrderId   String?
  providerPaymentId String?         @unique
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("INR")
  method            PaymentMethod?
  status            PaymentStatus   @default(PENDING)
  fullPayload       Json?
  createdAt         DateTime        @default(now())
  booking           Booking         @relation(fields: [bookingId], references: [id])
}

model BookingParticipant {
  id                     String   @id @default(uuid())
  bookingId              String
  isPrimary              Boolean  @default(false)
  name                   String
  email                  String?
  phoneNumber            String?
  gender                 String?
  age                    Int?
  bloodGroup             String?
  emergencyContactName   String?
  emergencyContactNumber String?
  emergencyRelationship  String?
  pickupPoint            String?
  dropPoint              String?
  attended               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  booking                Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model TripAssignment {
  id         String @id @default(uuid())
  slotId     String
  trekLeadId String
  slot       Slot   @relation(fields: [slotId], references: [id])
  trekLead   User   @relation("TrekLeadAssignments", fields: [trekLeadId], references: [id])

  @@unique([slotId, trekLeadId])
}

model TripLog {
  id           String   @id @default(uuid())
  slotId       String   @unique
  attendees    Json?
  photoUrls    String[]
  trekLeadNote String?
  managerNote  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  slot         Slot     @relation(fields: [slotId], references: [id])
}

model Blog {
  id              String      @id @default(uuid())
  title           String
  slug            String      @unique
  content         Json
  authorId        String
  experienceId    String?
  coverImageId    String?
  status          BlogStatus  @default(DRAFT)
  rejectionReason String?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  authorSocials   Json?
  coverImageUrl   String?
  theme           String      @default("CLASSIC")
  author          User        @relation(fields: [authorId], references: [id])
  coverImage      Image?      @relation(fields: [coverImageId], references: [id])
  experience      Experience? @relation(fields: [experienceId], references: [id])
}

model Image {
  id           String    @id @default(uuid())
  originalUrl  String
  mediumUrl    String?
  thumbUrl     String?
  type         MediaType @default(IMAGE)
  uploadedById String
  createdAt    DateTime  @default(now())
  fileHash     String?   @unique
  blogCovers   Blog[]
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model HeroSlide {
  id       String  @id @default(uuid())
  title    String
  subtitle String?
  videoUrl String
  ctaLink  String?
  order    Int
  isActive Boolean @default(true)
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  timestamp  DateTime @default(now())

  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model SiteSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model AdventureQuote {
  id        String   @id @default(uuid())
  text      String
  author    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ExperienceReview {
  id                   String     @id @default(uuid())
  rating               Int        @db.SmallInt
  reviewText           String
  experienceId         String
  userId               String
  isFeaturedHome       Boolean    @default(false)
  isFeaturedExperience Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  experience           Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([experienceId, userId])
}

model SavedExperience {
  id           String     @id @default(uuid())
  userId       String
  experienceId String
  savedAt      DateTime   @default(now())
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experienceId])
}

model CustomLead {
  id           String     @id @default(uuid())
  name         String
  email        String
  phone        String
  requirements String
  status       LeadStatus @default(NEW)
  adminNotes   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PlatformSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model StoryBlock {
  id        String   @id @default(uuid())
  type      String
  title     String
  subtitle  String?
  body      String?
  imageUrl  String?
  stat      String?
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum ExperienceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Difficulty {
  EASY
  MODERATE
  HARD
  EXTREME
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUND_PENDING
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
  MANUAL
}

enum PaymentMethod {
  CARD
  UPI
  NETBANKING
  WALLET
  OTHER
}

enum BlogStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
}

enum TripStatus {
  UPCOMING
  ACTIVE
  TREK_STARTED
  TREK_ENDED
  COMPLETED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
  DISCARDED
}
