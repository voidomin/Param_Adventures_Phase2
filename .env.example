# ──────────────────────────────────────────────────────────────────────────────
# PARAM ADVENTURES — ENVIRONMENT CONFIGURATION (V1.0.0 Stable)
# ──────────────────────────────────────────────────────────────────────────────
# This file defines the strictly required INFRASTRUCTURE variables.
# Operational settings (SMTP, Resend, Maintenance, etc.) are now managed
# via the "System Governance" Dashboard in the Admin Command Center.

# ─── CORE INFRASTRUCTURE ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"
JWT_SECRET="generate-a-secure-random-64-character-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000

# ─── MEDIA ENGINE (Cloudinary) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── PAYMENT GATEWAY (Razorpay) ──────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="secret_..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."

# ─── SENTRY MONITORING (Error Tracking) ──────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxx@o0.ingest.sentry.io/450"
SENTRY_AUTH_TOKEN="your_auth_token"
SENTRY_ORG="param-adventures-0e"
SENTRY_PROJECT="javascript-nextjs"

# ─── UTILITY & AUTOMATION ────────────────────────────────────────────────────
CRON_SECRET="your_cron_secret" # Required for automated cleanup tasks

# ─── INITIAL SETUP (Optional / Temporary) ────────────────────────────────────
ALLOW_DEFAULT_SUPER_ADMINS=false
SEND_INVITES=false
