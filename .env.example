# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres@localhost:5432/param_adventure?schema=public"

# JWT Authentication
JWT_SECRET=param-adventure-dev-secret-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# Email (Transactional - Zoho SMTP)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_USER=booking@paramadventures.in
SMTP_PASS=your-zoho-app-password
SMTP_FROM="Param Adventures <booking@paramadventures.in>"

# Cloudinary (Media Management)
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# AWS (S3 Storage)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=...
# Backward-compatible fallback name (optional)
S3_BUCKET_NAME=...

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# RBAC Security
# Seed is blocked in production unless FORCE_SEED=true is set for the seed command.
FORCE_SEED=false

# Super admin bootstrap (recommended in production)
ADMIN_EMAIL=admin@paramadventure.com
# Comma-separated list for multiple bootstrap admins
SUPER_ADMIN_EMAILS=admin@paramadventure.com,ops@paramadventure.com

# Only set true if you intentionally want hardcoded default admin emails in production seed
ALLOW_DEFAULT_SUPER_ADMINS=false

# Optional: send invite emails from seed script
SEND_INVITES=false
