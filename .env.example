# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres@localhost:5432/param_adventure?schema=public"

# JWT Authentication
JWT_SECRET=param-adventure-dev-secret-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# Email (Transactional - Zoho SMTP)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_USER=hello@paramadventures.in
SMTP_PASS=your-zoho-app-password
SMTP_FROM="Param Adventures <hello@paramadventures.in>"

# Cloudinary (Media Management)
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# AWS (S3 Storage)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_BUCKET_NAME=...

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# RBAC Security
# Initial Bootstrap Super Admin (Created on npm run seed)
ADMIN_EMAIL=admin@paramadventure.com
ADMIN_PASSWORD=change-me-immediately
