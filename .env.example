# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres@localhost:5432/param_adventure?schema=public"

# JWT Authentication
JWT_SECRET=param-adventure-dev-secret-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# AWS (Media & Notifications)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_BUCKET_NAME=...

# RBAC Security
# Comma-separated list of emails allowed to be promoted to SUPER_ADMIN
SUPER_ADMIN_ALLOWED_EMAILS=admin@paramadventure.com,owner@domain.com
# Initial Bootstrap Super Admin (Created on npm run seed)
ADMIN_EMAIL=admin@paramadventure.com
ADMIN_PASSWORD=change-me-immediately
